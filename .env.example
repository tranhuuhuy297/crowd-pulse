DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crowdpulse
REDIS_URL=redis://localhost:6379
API_PORT=4177

# Reddit API credentials (script-type app from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Telegram bot token (from @BotFather — optional, bot disabled if not set)
TELEGRAM_BOT_TOKEN=
