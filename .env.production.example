# CrowdPulse Production Environment Variables
# Copy this file and fill in real values.
# In production (GCP Cloud Run), these are sourced from Secret Manager.
# NEVER commit real values to git.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=4177

# ── Database (Postgres) ───────────────────────────────────────────────────────
# GCP Cloud SQL:  postgresql://USER:PASS@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
# Neon free tier: postgresql://USER:PASS@ep-xxx.us-east-2.aws.neon.tech/crowdpulse?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crowdpulse

# ── Redis ─────────────────────────────────────────────────────────────────────
# GCP Memorystore: redis://10.x.x.x:6379
# Upstash free:    rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── Reddit API credentials ────────────────────────────────────────────────────
# Create app at: https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── GCP (for manual deploy only — CI uses Workload Identity Federation) ───────
GCP_PROJECT_ID=your-gcp-project-id
